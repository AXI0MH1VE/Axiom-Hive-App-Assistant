# Verity Assistant Environment Configuration
# Copy this file to .env and fill in values

# ── LLM Provider API Keys ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
PUBMED_API_KEY=optional-pubmed-key-for-higher-rate-limits

# ── Application Settings ───────────────────────────────────────────────────────
APP_ENV=development  # or production, test
DEBUG=false
LOG_LEVEL=INFO

# ── Server Configuration ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=true  # Set to false in production

# ── CORS & Security ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
API_KEY_REQUIRED=false
API_KEY=your-secret-api-key-here  # If API_KEY_REQUIRED=true

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=10

# ── Redis Cache (optional) ─────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

# ── Database / Audit ───────────────────────────────────────────────────────────
AUDIT_DB_PATH=data/audit/audit.db
AUDIT_LOG_ENCRYPTION=false
AUDIT_HMAC_KEY=rotate-this-key-every-30-days-at-least-32-bytes
AUDIT_RETENTION_DAYS=365

# ── Knowledge Corpus ───────────────────────────────────────────────────────────
CORPUS_VERSION=2024.06.1
KNOWLEDGE_DIR=knowledge/
MAX_CORPUS_AGE_DAYS=90
ENFORCE_CORPUS_FRESHNESS=true

# ── Retrieval Settings ─────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.65
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=knowledge/embeddings/wikipedia_202406.faiss

# ── Copyright Detection ────────────────────────────────────────────────────────
COPYRIGHT_CHECK_ENABLED=true
COPYRIGHT_BLEU_THRESHOLD=0.3
COPYRIGHT_COSINE_THRESHOLD=0.6
COPYRIGHTED_WORKS_CORPUS_PATH=knowledge/raw/copyrighted_works/

# ── Fact Validation ────────────────────────────────────────────────────────────
NLI_MODEL=roberta-large-mnli
NLI_THRESHOLD=0.8
MAX_REGENERATION_ATTEMPTS=2

# ── Confidence Thresholds ──────────────────────────────────────────────────────
CONFIDENCE_HIGH_MIN_SOURCES=3
CONFIDENCE_MEDIUM_MIN_SOURCES=1
CONFIDENCE_RECENCY_WEIGHT_DAYS=365

# ── Local LLM (Ollama) ─────────────────────────────────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b-instruct-q4_K_M
OLLAMA_TIMEOUT=60

# ── Feedback & Monitoring ──────────────────────────────────────────────────────
FEEDBACK_QUEUE_PATH=data/feedback_queue.json
ENABLE_PROMETHEUS_METRICS=true
METRICS_PORT=9090

# ── Admin & Governance ─────────────────────────────────────────────────────────
ADMIN_API_KEY=change-this-admin-key-immediately
ALLOW_USER_DELETION=true
GDPR_COMPLIANCE_MODE=false

# ── Email (optional notifications) ────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=admin@example.com
