{
  "version": "1.0.0",
  "description": "Token and claim evaluation rules for factual constraint enforcement",
  "token_rules": [
    {
      "pattern": "\\b(definitely|certainly|undeniably|absolutely|without a doubt)\\b",
      "risk": 0.8,
      "action": "suppress",
      "rationale": "Absolute certainty claims are rarely justified in empirical domains"
    },
    {
      "pattern": "\\b(probably|might|maybe|perhaps|possibly|potentially)\\b",
      "risk": 0.3,
      "action": "flag",
      "rationale": "Speculative language indicates insufficient evidence"
    },
    {
      "pattern": "\\b(I think|in my opinion|personally|from my perspective)\\b",
      "risk": 0.1,
      "action": "allow",
      "rationale": "Explicit opinion markers are acceptable when clearly attributed to speaker"
    },
    {
      "pattern": "\\b(always|never|everyone|no one)\\b",
      "risk": 0.6,
      "action": "flag",
      "rationale": "Universal quantifiers require exceptional evidence"
    }
  ],
  "fact_rules": [
    {
      "type": "unsourced_claim",
      "condition": "no_citation_markers AND contains_factual_statement",
      "action": "require_citation",
      "severity": "high"
    },
    {
      "type": "unverified_statistic",
      "condition": "contains_numeric_value AND contains_percentage",
      "action": "cross_check",
      "severity": "high"
    },
    {
      "type": "temporal_claim",
      "condition": "contains_date OR contains_time_reference",
      "action": "verify_recency",
      "severity": "medium"
    },
    {
      "type": "causal_claim",
      "condition": "contains_causality_keywords AND not_attributed",
      "action": "require_direct_quotation",
      "severity": "high"
    }
  ],
  "copyright_rules": [
    {
      "type": "long_quote",
      "threshold_chars": 50,
      "action": "summarize_or_attribute",
      "rationale": "Quotes exceeding 50 characters must be explicitly attributed with source"
    },
    {
      "type": "high_similarity",
      "threshold_bleu": 0.3,
      "threshold_cosine": 0.6,
      "action": "block_regenerate",
      "max_attempts": 2,
      "rationale": "Surface overlap with copyrighted works indicates misappropriation risk"
    },
    {
      "type": "plagiarism_risk",
      "threshold_uniqueness": 0.2,
      "action": "regenerate",
      "rationale": "Generated text too similar to single source lacks originality"
    }
  ],
  "pii_rules": [
    {
      "entity_type": "PERSON",
      "action": "redact",
      "rationale": "Personal names are PII requiring protection"
    },
    {
      "entity_type": "EMAIL_ADDRESS",
      "action": "redact"
    },
    {
      "entity_type": "PHONE_NUMBER",
      "action": "redact"
    },
    {
      "entity_type": "CREDIT_CARD",
      "action": "redact"
    },
    {
      "entity_type": "SSN",
      "action": "redact"
    },
    {
      "entity_type": "LOCATION",
      "action": "flag",
      "note": "Precise addresses flagged for review; general locations permitted"
    }
  ]
}
